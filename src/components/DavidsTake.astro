---
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<aside
  class="relative rounded-xl border border-brand-200 bg-brand-50 p-4 pl-5 dark:border-brand-500/30 dark:bg-brand-500/10"
>
  <div class="flex items-center gap-2.5">
    <span
      class="grid h-7 w-7 place-items-center rounded-full bg-brand-600 text-sm font-bold text-white"
      >DJ</span
    >
    <span
      class="text-xs font-bold uppercase tracking-wider text-brand-700 dark:text-brand-300"
      >David's take</span
    >
  </div>
  <p class="mt-2.5 text-sm leading-relaxed text-slate-700 dark:text-slate-200">
    {text}
  </p>
</aside>
