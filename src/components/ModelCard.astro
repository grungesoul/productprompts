---
import { withBase } from '../lib/url';

interface Props {
  model: {
    id: string;
    name: string;
    provider: 'Claude' | 'ChatGPT' | 'Gemini';
    vendor: string;
    tier: string;
    tagline: string;
    pricing?: { input: string; output: string };
    status: string;
    status_note?: string;
  };
}
const { model } = Astro.props;

const providerColor: Record<string, string> = {
  Claude: 'var(--claude)',
  ChatGPT: 'var(--chatgpt)',
  Gemini: 'var(--gemini)',
};
const tierLabel: Record<string, string> = {
  flagship: 'Flagship',
  balanced: 'Balanced',
  fast: 'Fast & cheap',
  reasoning: 'Reasoning',
};
const accent = providerColor[model.provider];
---

<a
  href={withBase(`/models/${model.id}`)}
  class="group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700"
  data-provider={model.provider}
  data-tier={model.tier}
>
  <span
    class="absolute left-0 top-5 h-8 w-1 rounded-r"
    style={`background:${accent}`}></span>
  <div class="flex items-start justify-between gap-2">
    <div>
      <span
        class="text-xs font-semibold uppercase tracking-wide"
        style={`color:${accent}`}>{model.provider}</span
      >
      <h3 class="mt-0.5 text-lg font-bold leading-tight text-slate-900 dark:text-white">
        {model.name}
      </h3>
    </div>
    <span
      class="shrink-0 rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300"
      >{tierLabel[model.tier] ?? model.tier}</span
    >
  </div>

  <p class="mt-2 grow text-sm leading-relaxed text-slate-600 dark:text-slate-400">
    {model.tagline}
  </p>

  <div class="mt-4 flex items-center justify-between">
    {
      model.pricing ? (
        <span class="text-xs text-slate-500 dark:text-slate-500">
          {model.pricing.input} in · {model.pricing.output} out
        </span>
      ) : (
        <span class="text-xs text-slate-400">See provider pricing</span>
      )
    }
    {
      model.status === 'rolling-out' && (
        <span class="rounded bg-amber-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
          Rolling out
        </span>
      )
    }
  </div>
  <span
    class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 opacity-0 transition group-hover:opacity-100"
  >
    Prompting guide
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
  </span>
</a>
