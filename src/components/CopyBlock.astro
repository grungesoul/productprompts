---
interface Props {
  code: string;
  label?: string;
}
const { code, label } = Astro.props;
---

<div
  class="copy-block group relative overflow-hidden rounded-xl border border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-900"
>
  {
    label && (
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-2 dark:border-slate-700">
        <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
          {label}
        </span>
      </div>
    )
  }
  <button
    type="button"
    class="copy-btn absolute right-2.5 top-2.5 z-10 flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-2.5 py-1 text-xs font-medium text-slate-600 shadow-sm transition hover:border-brand-400 hover:text-brand-600 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-300"
    style={label ? 'top: 2.75rem;' : ''}
    data-code={code}
  >
    <svg class="copy-icon h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
    <span class="copy-label">Copy</span>
  </button>
  <pre class="overflow-x-auto px-4 py-4 text-[13px] leading-relaxed text-slate-800 dark:text-slate-200"><code>{code}</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        // Fallback for non-secure contexts
        const ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      const label = btn.querySelector('.copy-label');
      if (label) {
        const original = label.textContent;
        label.textContent = 'Copied!';
        btn.classList.add('text-brand-600', 'border-brand-400');
        setTimeout(() => {
          label.textContent = original;
          btn.classList.remove('text-brand-600', 'border-brand-400');
        }, 1600);
      }
    });
  });
</script>
