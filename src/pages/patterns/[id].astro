---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CopyBlock from '../../components/CopyBlock.astro';
import DavidsTake from '../../components/DavidsTake.astro';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map((p) => ({
    params: { id: p.id },
    props: { pattern: p.data },
  }));
}

const { pattern } = Astro.props;

const providerColor: Record<string, string> = {
  Claude: 'var(--claude)',
  ChatGPT: 'var(--chatgpt)',
  Gemini: 'var(--gemini)',
};
---

<Layout
  title={`${pattern.title} — product prompt pattern`}
  description={pattern.summary}
>
  <div class="mx-auto max-w-3xl px-5 py-10">
    <a
      href={withBase('/#patterns')}
      class="inline-flex items-center gap-1 text-sm font-medium text-slate-500 transition hover:text-brand-600"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
      All patterns
    </a>

    <header class="mt-5 flex items-start gap-4">
      <span
        class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl bg-brand-50 text-3xl dark:bg-brand-500/10"
        >{pattern.icon}</span
      >
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">
          {pattern.title}
        </h1>
        <p class="mt-1.5 text-base text-slate-600 dark:text-slate-300">
          {pattern.summary}
        </p>
      </div>
    </header>

    <p
      class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-700 dark:border-slate-800 dark:bg-slate-900/60 dark:text-slate-300"
    >
      {pattern.intro}
    </p>

    <!-- Model-tuned variants -->
    <div class="mt-8 space-y-6">
      {
        pattern.variants.map((v) => (
          <section class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
            <div class="flex items-center gap-2">
              <span
                class="rounded-full px-2.5 py-1 text-xs font-bold text-white"
                style={`background:${providerColor[v.provider]}`}
              >
                {v.provider}
              </span>
              <h2 class="text-base font-bold text-slate-900 dark:text-white">
                {v.model_name}
              </h2>
            </div>

            <p class="mt-3 flex gap-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              <span class="font-semibold text-brand-600">Why this variant:</span>
              <span>{v.why}</span>
            </p>

            <div class="mt-3">
              <CopyBlock code={v.prompt} label={`Prompt for ${v.model_name}`} />
            </div>
          </section>
        ))
      }
    </div>

    {
      pattern.davids_take && (
        <section class="mt-8">
          <DavidsTake text={pattern.davids_take} />
        </section>
      )
    }
  </div>
</Layout>
