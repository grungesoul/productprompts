---
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ProductPrompts — a prompting guide for product leaders',
  description = 'Tune your prompts to the model. A model-aware prompting reference for product teams across Claude, ChatGPT, and Gemini — get the output you expect, in fewer tokens.',
} = Astro.props;

const nav = [
  { label: 'Models', href: withBase('/#models') },
  { label: 'Patterns', href: withBase('/#patterns') },
  { label: 'Which model?', href: withBase('/which-model') },
  { label: 'Best practices', href: withBase('/best-practices') },
];
const ogImage = withBase('/og.svg');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <!-- Open Graph / social cards for LinkedIn + Product Hunt sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Set theme before paint to avoid a flash of the wrong mode. -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia(
          '(prefers-color-scheme: dark)'
        ).matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-white text-slate-800 antialiased dark:bg-slate-950 dark:text-slate-200"
  >
    <header
      class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80"
    >
      <div
        class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5"
      >
        <a
          href={withBase('/')}
          class="group flex items-center gap-2 font-extrabold tracking-tight"
        >
          <svg
            viewBox="0 0 32 32"
            class="h-7 w-7 shrink-0 transition group-hover:scale-105"
            aria-hidden="true"
          >
            <rect width="32" height="32" rx="8" fill="#4f46e5"></rect>
            <polyline
              points="11,10 17,16 11,22"
              fill="none"
              stroke="#ffffff"
              stroke-width="3.2"
              stroke-linecap="round"
              stroke-linejoin="round"></polyline>
            <rect x="18" y="20" width="6" height="2.6" rx="1.3" fill="#ffffff"
            ></rect>
          </svg>
          <span>Product<span class="text-brand-600">Prompts</span></span>
        </a>
        <nav class="flex items-center gap-1 text-sm font-medium">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="rounded-md px-3 py-1.5 text-slate-600 transition hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white"
              >
                {item.label}
              </a>
            ))
          }
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="ml-1 grid h-8 w-8 place-items-center rounded-md text-slate-600 transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800"
          >
            <svg
              class="hidden h-4 w-4 dark:block"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4.95 2.05a1 1 0 010 1.41l-.71.71a1 1 0 11-1.41-1.41l.71-.71a1 1 0 011.41 0zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 14.95a1 1 0 011.41 0l.71.71A1 1 0 015.76 17l-.71-.71a1 1 0 010-1.34zM4 10a1 1 0 01-1 1H2a1 1 0 110-2h1a1 1 0 011 1zm1.05-5.95a1 1 0 011.41 1.41l-.71.71A1 1 0 014.34 4.76l.71-.71zM10 6a4 4 0 100 8 4 4 0 000-8z"
              ></path></svg
            >
            <svg
              class="block h-4 w-4 dark:hidden"
              fill="currentColor"
              viewBox="0 0 20 20"
              ><path
                d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
              ></path></svg
            >
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer
      class="mt-24 border-t border-slate-200 py-10 dark:border-slate-800"
    >
      <div
        class="mx-auto flex max-w-5xl flex-col items-center gap-2 px-5 text-center text-sm text-slate-500 dark:text-slate-400"
      >
        <p>
          Built by <a
            href="https://www.linkedin.com/in/davidjordansoro"
            class="font-semibold text-brand-600 hover:underline">David Jordan</a
          > — Product Coach. Free & open source.
        </p>
        <p class="text-xs">
          Model facts carry a “last verified” date. Models change weekly — if
          something looks off, <a
            href="https://www.linkedin.com/in/davidjordansoro"
            class="underline hover:text-brand-600">tell me</a
          >.
        </p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
